{
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/**/*.py": {
      "runtime": "@vercel/python@4.3.1"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET" }
      ]
    }
  ]
}
